999" end="3:31.384">cya</span><span begin="3:35.672" end="3:36.052">te</span> <span begin="3:36.052" end="3:36.408">tā</span><span begin="3:36.408" end="3:36.766">va</span><span begin="3:36.766" end="3:37.141">d</span> <span begin="3:40.413" end="3:40.577">a</span><span begin="3:40.577" end="3:40.948">bad</span><span begin="3:40.948" end="3:41.143">dho</span> <span begin="3:41.143" end="3:41.475">nai</span><span begin="3:41.475" end="3:41.853">va</span> <span begin="3:41.853" end="3:42.182">mu</span><span begin="3:42.182" end="3:42.570">cya</span><span begin="3:42.570" end="3:42.952">te</span><span ttm:role="x-translation" xml:lang="zh-CN">缚者无有解 无缚亦无解</span><span ttm:role="x-roman">跋多那目遮谛 陀婆陀跋多 那缚目遮谛</span></p><p begin="3:32.807" end="3:47.272" itunes:key="L22" ttm:agent="v2"><span begin="3:32.807" end="3:33.192">Lu</span><span begin="3:33.192" end="3:33.492">nae</span> <span begin="3:33.534" end="3:33.910">fal</span><span begin="3:33.910" end="3:34.251">sae</span> <span begin="3:38.582" end="3:38.965">dis</span><span begin="3:38.965" end="3:39.303">sol</span><span begin="3:39.303" end="3:39.676">ve</span><span begin="3:39.676" end="3:40.028">re</span> <span begin="3:42.923" end="3:43.276">ne</span><span begin="3:43.276" end="3:43.660">que</span><span begin="3:43.660" end="3:44.391">unt</span> <span begin="3:45.818" end="3:46.183">no</span><span begin="3:46.183" end="3:46.559">bis</span> <span begin="3:46.559" end="3:46.913">fa</span><span begin="3:46.913" end="3:47.272">tum</span><span ttm:role="x-translation" xml:lang="zh-CN">破碎的伪月不会为我等解开缚颈的命运</span></p><p begin="3:44.397" end="3:45.828" itunes:key="L23" ttm:agent="v1"><span begin="3:44.397" end="3:44.706">Na</span> <span begin="3:44.750" end="3:45.109">mu</span><span begin="3:45.109" end="3:45.439">cya</span><span begin="3:45.468" end="3:45.828">te</span><span ttm:role="x-translation" xml:lang="zh-CN">无解即无救</span><span ttm:role="x-roman">那目遮谛</span></p><p begin="3:47.272" end="3:49.807" itunes:key="L24" ttm:agent