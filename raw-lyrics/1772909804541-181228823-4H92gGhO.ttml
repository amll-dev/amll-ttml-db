<tt xmlns="http://www.w3.org/ns/ttml" xmlns:amll="http://www.example.com/ns/amll" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><amll:meta key="musicName" value="Together Forever"/><amll:meta key="artists" value="Rick Astley"/><amll:meta key="album" value="Whenever You Need Somebody"/><amll:meta key="isrc" value="GBARL9300136"/><amll:meta key="appleMusicId" value="1559523363"/><amll:meta key="ncmMusicId" value="18520490"/><amll:meta key="spotifyId" value="00isIFJWVpXIQ8HkGICSQp"/><amll:meta key="ttmlAuthorGithub" value="181228823"/><amll:meta key="ttmlAuthorGithubLogin" value="watercooling480"/></metadata></head><body dur="3:21.722"><div begin="19.508" end="3:21.722"><p begin="19.508" end="22.607" itunes:key="L1" ttm:agent="v1"><span begin="19.508" end="19.967">If</span> <span begin="19.967" end="20.705">there&apos;s</span> <span begin="21.056" end="21.562">anything</span> <span begin="21.562" end="21.841">you</span> <span begin="21.841" end="22.607">need</span><span ttm:role="x-translation" xml:lang="zh-CN">若你有所需</span></p><p begin="23.141" end="26.147" itunes:key="L2" ttm:agent="v1"><span begin="23.141" end="23.393">All</span> <span begin="23.393" end="23.690">you</span> <span begin="23.690" end="23.942">have</span> <span begin="23.942" end="24.230">to</span> <span begin="24.230" end="24.455">do</span> <span begin="24.455" end="24.969">is</span> <span begin="24.969" end="26.147">say</span><span ttm:role="x-translation" xml:lang="zh-CN">只需开口言明</span></p><p begin="26.141" end="30.977" itunes:key="L3" ttm:agent="v1"><span begin="26.141" end="26.340">You</span> <span begin="26.340" end="26.820">know</span> <span begin="26.820" end="27.345">you</span> <span begin="27.781" end="28.157">satis</span><span begin="28.157" end="29.060">fy</span> <span begin="29.364" end="29.897">everything</span> <span begin="29.897" end="30.185">in</span> <span begin="30.185" end="30.977">me</span><span ttm:role="x-translation" xml:lang="zh-CN">你知你满足我生命一切</span></p><p begin="31.242" end="34.374" itunes:key="L4" ttm:agent="v1"><span begin="31.242" end="31.534">We</span> <span begin="31.534" end="32.002">shouldn&apos;t</span> <span begin="32.002" end="32.249">waste</span> <span begin="32.249" end="32.503">a</span> <span begin="32.503" end="32.928">single</span> <span begin="32.928" end="34.374">day</span><span ttm:role="x-translation" xml:lang="zh-CN">我们不该虚度任何光阴</span></p><p begin="35.382" end="39.330" itunes:key="L5" ttm:agent="v1"><span begin="35.382" end="35.637">So</span> <span begin="35.637" end="36.018">don&apos;t</span> <span begin="36.018" end="36.360">stop</span> <span begin="36.360" end="36.702">me</span> <span begin="36.702" end="37.539">falling,</span> <span begin="37.539" end="37.755">it&apos;s</span> <span begin="37.755" end="38.446">destiny</span> <span begin="38.446" end="39.330">calling</span><span ttm:role="x-translation" xml:lang="zh-CN">所以别阻止我坠落 这是命运的呼唤</span></p><p begin="39.608" end="43.409" itunes:key="L6" ttm:agent="v1"><span begin="39.608" end="39.855">A</span> <span begin="39.855" end="40.457">power</span> <span begin="40.646" end="40.862">I</span> <span begin="40.862" end="41.095">just</span> <span begin="41.095" end="41.332">can&apos;t</span> <span begin="41.332" end="41.636">de</span><span begin="41.636" end="43.409">ny</span><span ttm:role="x-translation" xml:lang="zh-CN">一股我无法否认的力量</span></p><p begin="44.013" end="47.787" itunes:key="L7" ttm:agent="v1"><span begin="44.013" end="44.309">It&apos;s</span> <span begin="44.309" end="44.772">never</span> <span begin="44.772" end="45.717">changing,</span> <span begin="45.717" end="45.944">can&apos;t</span> <span begin="45.944" end="46.158">you</span> <span begin="46.158" end="46.411">hear</span> <span begin="46.411" end="46.752">me?</span> <span begin="46.752" end="47.083">I&apos;m</span> <span begin="47.083" end="47.787">saying</span><span ttm:role="x-translation" xml:lang="zh-CN">永不改变 你听不见吗 我在诉说</span></p><p begin="47.994" end="51.791" itunes:key="L8" ttm:agent="v1"><span begin="47.994" end="48.228">I</span> <span begin="48.228" end="48.435">want</span> <span begin="48.435" end="48.682">you</span> <span begin="48.682" end="48.939">for</span> <span begin="48.939" end="49.236">the</span> <span begin="49.236" end="49.470">rest</span> <span begin="49.470" end="49.722">of</span> <span begin="49.722" end="49.965">my</span> <span begin="49.965" end="51.791">life</span><span ttm:role="x-translation" xml:lang="zh-CN">我余生都想要你</span></p><p begin="52.053" end="55.932" itunes:key="L9" ttm:agent="v1"><span begin="52.053" end="52.809">Together</span> <span begin="52.809" end="53.862">forever</span> <span begin="53.862" end="54.088">and</span> <span begin="54.088" end="54.950">never</span> <span begin="54.950" end="55.205">to</span> <span begin="55.205" end="55.932">part</span><span ttm:role="x-translation" xml:lang="zh-CN">永远在一起 永不分离</span></p><p begin="56.211" end="59.768" itunes:key="L10" ttm:agent="v1"><span begin="56.211" end="56.958">Together</span> <span begin="56.958" end="58.042">forever,</span> <span begin="58.042" end="58.254">we&apos;re</span> <span begin="58.254" end="59.768">two</span><span ttm:role="x-translation" xml:lang="zh-CN">永远在一起 我们两人</span></p><p begin="1:00.382" end="1:08.493" itunes:key="L11" ttm:agent="v1"><span begin="1:00.382" end="1:00.657">And</span> <span begin="1:00.657" end="1:00.906">don&apos;t</span> <span begin="1:00.906" end="1:01.147">you</span> <span begin="1:01.147" end="1:01.422">know,</span> <span begin="1:01.422" end="1:01.935">I</span> <span begin="1:01.935" end="1:02.223">would</span> <span begin="1:02.223" end="1:02.477">move</span> <span begin="1:02.477" end="1:03.249">Heaven</span> <span begin="1:03.249" end="1:03.474">and</span> <span begin="1:03.474" end="1:04.029">Earth</span> <span begin="1:04.029" end="1:04.284">to</span> <span begin="1:04.284" end="1:04.532">be</span> <span begin="1:04.532" end="1:05.271">together</span> <span begin="1:05.271" end="1:06.378">forever</span> <span begin="1:06.378" end="1:06.900">with</span> <span begin="1:06.900" end="1:08.493">you?</span><span ttm:role="x-translation" xml:lang="zh-CN">你难道不知 我会翻天覆地 只为与你永远相守</span></p><p begin="1:09.564" end="1:12.858" itunes:key="L12" ttm:agent="v1"><span begin="1:09.564" end="1:10.077">If</span> <span begin="1:10.077" end="1:10.734">they</span> <span begin="1:11.103" end="1:11.481">ever</span> <span begin="1:11.481" end="1:11.706">get</span> <span begin="1:11.706" end="1:11.949">you</span> <span begin="1:11.949" end="1:12.858">down</span><span ttm:role="x-translation" xml:lang="zh-CN">若他们令你沮丧</span></p><p begin="1:12.950" end="1:16.045" itunes:key="L13" ttm:agent="v1"><span begin="1:12.950" end="1:13.212">There&apos;s</span> <span begin="1:13.212" end="1:13.670">always</span> <span begin="1:13.670" end="1:14.173">something</span> <span begin="1:14.173" end="1:14.443">I</span> <span begin="1:14.443" end="1:14.713">can</span> <span begin="1:14.713" end="1:16.045">do</span><span ttm:role="x-translation" xml:lang="zh-CN">总有我能做的事</span></p><p begin="1:16.083" end="1:21.040" itunes:key="L14" ttm:agent="v1"><span begin="1:16.083" end="1:16.758">Because</span> <span begin="1:16.758" end="1:17.280">I</span> <span begin="1:17.856" end="1:18.360">wouldn&apos;t</span> <span begin="1:18.360" end="1:19.429">ever</span> <span begin="1:19.429" end="1:19.809">wanna</span> <span begin="1:19.809" end="1:19.972">see</span> <span begin="1:19.972" end="1:20.257">you</span> <span begin="1:20.257" end="1:21.040">frown</span><span ttm:role="x-translation" xml:lang="zh-CN">因为我永远不愿见你愁容</span></p><p begin="1:21.295" end="1:24.741" itunes:key="L15" ttm:agent="v1"><span begin="1:21.295" end="1:21.563">I&apos;ll</span> <span begin="1:21.563" end="1:22.066">always</span> <span begin="1:22.066" end="1:22.300">do</span> <span begin="1:22.300" end="1:22.562">what&apos;s</span> <span begin="1:22.562" end="1:22.802">best</span> <span begin="1:22.802" end="1:23.065">for</span> <span begin="1:23.065" end="1:24.741">you</span><span ttm:role="x-translation" xml:lang="zh-CN">我总会为你做最好的选择</span></p><p begin="1:25.422" end="1:29.550" itunes:key="L16" ttm:agent="v1"><span begin="1:25.422" end="1:25.671">There</span> <span begin="1:25.671" end="1:25.996">ain&apos;t</span> <span begin="1:25.996" end="1:26.418">no</span> <span begin="1:26.418" end="1:26.681">mist</span><span begin="1:26.681" end="1:27.102">a</span><span begin="1:27.102" end="1:27.523">king,</span> <span begin="1:27.523" end="1:27.750">it&apos;s</span> <span begin="1:27.750" end="1:28.190">true</span> <span begin="1:28.190" end="1:28.533">love</span> <span begin="1:28.533" end="1:28.785">we&apos;re</span> <span begin="1:28.785" end="1:29.550">making</span><span ttm:role="x-translation" xml:lang="zh-CN">毫无疑问 我们创造的是真爱</span></p><p begin="1:29.838" end="1:33.256" itunes:key="L17" ttm:agent="v1"><span begin="1:29.838" end="1:30.362">Something</span> <span begin="1:30.362" end="1:30.594">to</span> <span begin="1:30.594" end="1:31.140">last</span> <span begin="1:31.140" end="1:31.382">for</span> <span begin="1:31.382" end="1:31.644">all</span> <span begin="1:31.644" end="1:33.256">time</span><span ttm:role="x-translation" xml:lang="zh-CN">某种能永恒留存的东西</span></p><p begin="1:34.047" end="1:37.806" itunes:key="L18" ttm:agent="v1"><span begin="1:34.047" end="1:34.389">It&apos;s</span> <span begin="1:34.389" end="1:34.758">never</span> <span begin="1:34.758" end="1:35.810">changing,</span> <span begin="1:35.810" end="1:35.973">can&apos;t</span> <span begin="1:35.973" end="1:36.135">you</span> <span begin="1:36.135" end="1:36.477">hear</span> <span begin="1:36.477" end="1:36.846">me?</span> <span begin="1:36.846" end="1:37.155">I&apos;m</span> <span begin="1:37.155" end="1:37.806">saying</span><span ttm:role="x-translation" xml:lang="zh-CN">永不改变 你听不见吗 我在诉说</span></p><p begin="1:37.925" end="1:42.143" itunes:key="L19" ttm:agent="v1"><span begin="1:37.925" end="1:38.230">I</span> <span begin="1:38.230" end="1:38.456">want</span> <span begin="1:38.456" end="1:38.698">you</span> <span begin="1:38.698" end="1:38.973">for</span> <span begin="1:38.973" end="1:39.219">the</span> <span begin="1:39.219" end="1:39.463">rest</span> <span begin="1:39.463" end="1:39.722">of</span> <span begin="1:39.722" end="1:39.992">my</span> <span begin="1:39.992" end="1:42.143">life</span><span ttm:role="x-translation" xml:lang="zh-CN">我余生都想要你</span></p><p begin="1:42.078" end="1:45.969" itunes:key="L20" ttm:agent="v1"><span begin="1:42.078" end="1:42.829">Together</span> <span begin="1:42.829" end="1:43.881">forever</span> <span begin="1:43.881" end="1:44.086">and</span> <span begin="1:44.086" end="1:44.889">never</span> <span begin="1:44.889" end="1:45.140">to</span> <span begin="1:45.140" end="1:45.969">part</span><span ttm:role="x-translation" xml:lang="zh-CN">永远在一起 永不分离</span></p><p begin="1:46.216" end="1:49.937" itunes:key="L21" ttm:agent="v1"><span begin="1:46.216" end="1:46.965">Together</span> <span begin="1:46.965" end="1:48.005">forever,</span> <span begin="1:48.005" end="1:48.261">we&apos;re</span> <span begin="1:48.261" end="1:49.937">two</span><span ttm:role="x-translation" xml:lang="zh-CN">永远在一起 我们两人</span></p><p begin="1:50.418" end="1:58.661" itunes:key="L22" ttm:agent="v1"><span begin="1:50.418" end="1:50.688">And</span> <span begin="1:50.688" end="1:50.914">don&apos;t</span> <span begin="1:50.914" end="1:51.169">you</span> <span begin="1:51.169" end="1:51.425">know,</span> <span begin="1:51.425" end="1:51.902">I</span> <span begin="1:51.902" end="1:52.158">would</span> <span begin="1:52.158" end="1:52.392">move</span> <span begin="1:52.392" end="1:53.233">Heaven</span> <span begin="1:53.233" end="1:53.468">and</span> <span begin="1:53.468" end="1:54.089">Earth</span> <span begin="1:54.089" end="1:54.297">to</span> <span begin="1:54.297" end="1:54.508">be</span> <span begin="1:54.508" end="